{
	"name": "suneditor",
	"version": "3.0.0-beta.17",
	"description": "Vanilla javascript based WYSIWYG web editor",
	"author": "Yi JiHong",
	"license": "MIT",
	"main": "src/suneditor.js",
	"types": "types/index.d.ts",
	"sideEffects": [
		"./src/assets/css/*.css"
	],
	"engines": {
		"node": ">=14.0.0"
	},
	"scripts": {
		"dev": "webpack-dev-server --config webpack/dev.js",
		"start": "npm run dev",
		"build:dev": "cross-env NODE_ENV=development webpack --config webpack/builder.js",
		"build:prod": "cross-env NODE_ENV=production webpack --config webpack/builder.js",
		"lint": "eslint src",
		"lint:fix-js": "npx eslint \"src/**/*.js\" --fix",
		"lint:fix-ts": "npx eslint \"types/**/*.ts\" --fix",
		"lint:fix-all": "npx eslint \"src/**/*.js\" \"types/**/*.ts\" --fix",
		"ts-build": "(npx tsc || true) && barrelsby --delete --directory types --exclude \"typedef.d.ts\" && node scripts/fix-langs.cjs && node scripts/wrap-dts.cjs && node scripts/rename-index.cjs && node scripts/remove-this-params.cjs && node scripts/gen-options-dts.cjs && npm run lint:fix-ts",
		"i18n-build": "cross-env GOOGLE_APPLICATION_CREDENTIALS=./.env/google-api-service-account.json node scripts/i18n-sync.cjs --auto-translate && npx eslint \"src/langs/*.js\" --fix && npx eslint \"types/langs/_Lang.d.ts\" --fix",
		"test": "karma start",
		"update-browserslist": "npx browserslist@latest --update-db"
	},
	"bugs": {
		"url": "https://github.com/JiHong88/SunEditor/issues"
	},
	"homepage": "http://suneditor.com",
	"repository": {
		"type": "git",
		"url": "https://github.com/JiHong88/SunEditor.git"
	},
	"devDependencies": {
		"@babel/core": "^7.22.1",
		"@codemirror/lang-html": "^6.4.3",
		"@codemirror/lang-javascript": "^6.1.8",
		"@google-cloud/translate": "^9.0.1",
		"@octokit/rest": "^21.1.1",
		"@typescript-eslint/eslint-plugin": "^8.29.1",
		"@typescript-eslint/parser": "^8.29.1",
		"@webpack-cli/serve": "^2.0.4",
		"babel-loader": "^9.1.2",
		"barrelsby": "^2.8.1",
		"clean-webpack-plugin": "^4.0.0",
		"codemirror": "^6.0.1",
		"codemirror5": "npm:codemirror@^5.65.9",
		"cross-env": "^7.0.3",
		"css-loader": "^6.7.4",
		"css-minimizer-webpack-plugin": "^5.0.0",
		"csstype": "^3.1.2",
		"eslint-config-prettier": "^8.8.0",
		"eslint-plugin-compat": "^4.2.0",
		"eslint-plugin-prettier": "^4.2.1",
		"file-loader": "^6.2.0",
		"glob": "^11.0.1",
		"html-webpack-plugin": "^5.5.1",
		"jasmine": "^5.0.0",
		"jsdoc": "^4.0.4",
		"karma": "^6.4.2",
		"karma-chrome-launcher": "^3.2.0",
		"karma-firefox-launcher": "^2.1.2",
		"karma-jasmine": "^5.1.0",
		"karma-opera-launcher": "^1.0.0",
		"karma-safari-launcher": "^1.0.0",
		"karma-webpack": "^5.0.0",
		"katex": "^0.16.7",
		"mathjax-full": "^3.2.2",
		"mini-css-extract-plugin": "^2.7.6",
		"prettier": "^2.8.8",
		"terser-webpack-plugin": "^5.3.10",
		"typescript": "^5.8.3",
		"url-loader": "^4.1.1",
		"webpack": "^5.84.1",
		"webpack-cli": "^5.1.1",
		"webpack-dev-server": "^5.2.2",
		"webpack-merge": "^5.9.0"
	},
	"browserslist": [
		"chrome >= 80",
		"firefox >= 90",
		"safari >= 14.1",
		"edge >= 80",
		"opera >= 67",
		"ios >= 14.5",
		"android >= 80",
		"samsung >= 13",
		"not IE <= 11",
		"not dead"
	],
	"ignore": [
		"**/.*",
		"node_modules"
	],
	"files": [
		"src",
		"types",
		"dist",
		"README.md",
		"CONTRIBUTING.md",
		"LICENSE"
	],
	"keywords": [
		"suneditor",
		"wysiwyg",
		"wysiwyg editor",
		"wysiwyg html editor",
		"rich text",
		"rich text editor",
		"rich editor",
		"html editor",
		"html5 editor",
		"javascript editor",
		"javascript rich text editor",
		"vanilla javascript",
		"contenteditable",
		"lightweight editor",
		"lightweight rich text editor",
		"open source editor",
		"text formatting",
		"web editor",
		"browser editor"
	]
}