{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"permissions": {
		"allow": [
			"Bash(npm run:*)",
			"Bash(npm test:*)",
			"Bash(npx jest:*)",
			"Bash(npx playwright test:*)",
			"Bash(npx eslint:*)",
			"Bash(npx tsc:*)",
			"Bash(npm install:*)",
			"mcp__ide__getDiagnostics"
		],
		"deny": [],
		"ask": []
	},
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Edit|Write|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "f=$(jq -r \"(.tool_input.file_path) // empty\"); case \"$f\" in */src/*.js) out=$(npx eslint \"$f\" 2>&1) || { printf \"ESLint found issues in %s:\\n%s\\n\" \"$f\" \"$out\" >&2; exit 2; };; esac",
						"timeout": 30,
						"statusMessage": "ESLint (changed file)"
					}
				]
			}
		]
	}
}
